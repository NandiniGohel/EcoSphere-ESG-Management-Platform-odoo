<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="cron_esg_score_recompute" model="ir.cron">
            <field name="name">ESG: Nightly Department Score Recompute</field>
            <field name="model_id" ref="model_hr_department"/>
            <field name="state">code</field>
            <field name="code">model._cron_recompute_all_scores()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
            <field name="nextcall" eval="(datetime.now() + timedelta(days=1)).strftime('%Y-%m-%d 01:00:00')"/>
        </record>

        <record id="cron_esg_overdue_compliance" model="ir.cron">
            <field name="name">ESG: Flag Overdue Compliance Issues</field>
            <field name="model_id" ref="model_esg_compliance_issue"/>
            <field name="state">code</field>
            <field name="code">model._cron_flag_overdue()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
            <field name="nextcall" eval="(datetime.now() + timedelta(days=1)).strftime('%Y-%m-%d 02:00:00')"/>
        </record>

        <record id="cron_esg_score_snapshot" model="ir.cron">
            <field name="name">ESG: Daily Score Snapshot</field>
            <field name="model_id" ref="model_esg_department_score"/>
            <field name="state">code</field>
            <field name="code">model._cron_snapshot()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
            <field name="nextcall" eval="(datetime.now() + timedelta(days=1)).strftime('%Y-%m-%d 03:00:00')"/>
        </record>
    </data>
</odoo>
