<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="module_category_esg" model="ir.module.category">
            <field name="name">ESG Management</field>
            <field name="description">ESG Environmental, Social and Governance Management Platform</field>
            <field name="sequence">100</field>
        </record>

        <record id="group_esg_user" model="res.groups">
            <field name="name">ESG User</field>
            <field name="category_id" ref="module_category_esg"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_esg_manager" model="res.groups">
            <field name="name">ESG Manager</field>
            <field name="category_id" ref="module_category_esg"/>
            <field name="implied_ids" eval="[(4, ref('group_esg_user'))]"/>
        </record>
    </data>
</odoo>
