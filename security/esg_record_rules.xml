<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Record Rules for ESG Carbon Transactions -->
        <record id="rule_esg_carbon_transaction_dept" model="ir.rule">
            <field name="name">ESG Carbon Transaction: Own Department Only</field>
            <field name="model_id" ref="model_esg_carbon_transaction"/>
            <field name="domain_force">[('department_id', '=', user.employee_id.department_id.id)]</field>
            <field name="groups" eval="[(4, ref('esg_management.group_esg_user'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="rule_esg_carbon_transaction_manager" model="ir.rule">
            <field name="name">ESG Carbon Transaction: Manager All</field>
            <field name="model_id" ref="model_esg_carbon_transaction"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('esg_management.group_esg_manager'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <!-- Record Rules for CSR Participations -->
        <record id="rule_esg_employee_participation_own" model="ir.rule">
            <field name="name">ESG CSR Participation: Own Records Only</field>
            <field name="model_id" ref="model_esg_employee_participation"/>
            <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('esg_management.group_esg_user'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="rule_esg_employee_participation_manager" model="ir.rule">
            <field name="name">ESG CSR Participation: Manager All</field>
            <field name="model_id" ref="model_esg_employee_participation"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('esg_management.group_esg_manager'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <!-- Record Rules for Challenge Participations -->
        <record id="rule_esg_challenge_participation_own" model="ir.rule">
            <field name="name">ESG Challenge Participation: Own Records Only</field>
            <field name="model_id" ref="model_esg_challenge_participation"/>
            <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('esg_management.group_esg_user'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="rule_esg_challenge_participation_manager" model="ir.rule">
            <field name="name">ESG Challenge Participation: Manager All</field>
            <field name="model_id" ref="model_esg_challenge_participation"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('esg_management.group_esg_manager'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>
    </data>
</odoo>
