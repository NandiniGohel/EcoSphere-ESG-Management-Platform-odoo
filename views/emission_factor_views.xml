<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record id="view_esg_emission_factor_tree" model="ir.ui.view">
        <field name="name">esg.emission.factor.tree</field>
        <field name="model">esg.emission.factor</field>
        <field name="arch" type="xml">
            <list string="Emission Factors">
                <field name="name"/>
                <field name="factor_value"/>
                <field name="unit"/>
                <field name="scope"/>
                <field name="source"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_esg_emission_factor_form" model="ir.ui.view">
        <field name="name">esg.emission.factor.form</field>
        <field name="model">esg.emission.factor</field>
        <field name="arch" type="xml">
            <form string="Emission Factor">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" type="object"
                                class="oe_stat_button" icon="fa-archive"
                                invisible="not active">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Active</span>
                            </div>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived"
                            bg_color="bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Factor Details">
                            <field name="scope"/>
                            <field name="factor_value"/>
                            <field name="unit"/>
                            <field name="source"/>
                        </group>
                        <group string="Validity">
                            <field name="valid_from"/>
                            <field name="valid_to"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_esg_emission_factor_search" model="ir.ui.view">
        <field name="name">esg.emission.factor.search</field>
        <field name="model">esg.emission.factor</field>
        <field name="arch" type="xml">
            <search string="Search Emission Factors">
                <field name="name"/>
                <field name="scope"/>
                <field name="source"/>
                <separator/>
                <filter string="Scope 1" name="scope1" domain="[('scope', '=', 'scope1')]"/>
                <filter string="Scope 2" name="scope2" domain="[('scope', '=', 'scope2')]"/>
                <filter string="Scope 3" name="scope3" domain="[('scope', '=', 'scope3')]"/>
                <separator/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Scope" name="group_scope" context="{'group_by': 'scope'}"/>
                    <filter string="Source" name="group_source" context="{'group_by': 'source'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_esg_emission_factor" model="ir.actions.act_window">
        <field name="name">Emission Factors</field>
        <field name="res_model">esg.emission.factor</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_esg_emission_factor_search"/>
        <field name="context">{}</field>
    </record>
</odoo>
