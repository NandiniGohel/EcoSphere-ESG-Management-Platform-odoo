<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record id="view_esg_environmental_goal_tree" model="ir.ui.view">
        <field name="name">esg.environmental.goal.tree</field>
        <field name="model">esg.environmental.goal</field>
        <field name="arch" type="xml">
            <list string="Environmental Goals"
                  decoration-success="state == 'achieved'"
                  decoration-danger="state == 'missed'"
                  decoration-warning="state == 'active'">
                <field name="name"/>
                <field name="department_id"/>
                <field name="goal_type"/>
                <field name="target_value"/>
                <field name="current_value"/>
                <field name="unit"/>
                <field name="progress_percentage" widget="progressbar"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'achieved'"
                       decoration-warning="state == 'active'"
                       decoration-danger="state == 'missed'"/>
            </list>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_esg_environmental_goal_kanban" model="ir.ui.view">
        <field name="name">esg.environmental.goal.kanban</field>
        <field name="model">esg.environmental.goal</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="department_id"/>
                <field name="progress_percentage"/>
                <field name="state"/>
                <field name="goal_type"/>
                <field name="target_value"/>
                <field name="current_value"/>
                <field name="unit"/>
                <templates>
                    <t t-name="kanban-card">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_card_header">
                                <div class="o_kanban_card_header_title">
                                    <div class="o_primary">
                                        <field name="name"/>
                                    </div>
                                    <div class="o_secondary">
                                        <field name="department_id"/>
                                    </div>
                                </div>
                            </div>
                            <div class="o_kanban_card_content">
                                <div class="o_field_widget o_progressbar">
                                    <div class="o_progress">
                                        <div class="o_progress_value"
                                             t-att-style="'width: ' + record.progress_percentage.raw_value + '%'"
                                             t-att-class="record.progress_percentage.raw_value >= 100 ? 'o_progress_success' : 'o_progress_info'">
                                        </div>
                                    </div>
                                    <span><t t-esc="record.progress_percentage.raw_value"/>%</span>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <span class="o_kanban_tags_section">
                                        <field name="goal_type" widget="badge"/>
                                    </span>
                                    <span><t t-esc="record.current_value.raw_value"/> / <t t-esc="record.target_value.raw_value"/> <t t-esc="record.unit.raw_value"/></span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_esg_environmental_goal_form" model="ir.ui.view">
        <field name="name">esg.environmental.goal.form</field>
        <field name="model">esg.environmental.goal</field>
        <field name="arch" type="xml">
            <form string="Environmental Goal">
                <header>
                    <button name="action_activate" string="Activate" type="object"
                            invisible="state != 'draft'"
                            class="btn-primary"/>
                    <button name="action_achieve" string="Mark Achieved" type="object"
                            invisible="state != 'active'"
                            class="btn-success"/>
                    <button name="action_miss" string="Mark Missed" type="object"
                            invisible="state != 'active'"
                            class="btn-danger"/>
                    <button name="action_reset" string="Reset to Draft" type="object"
                            invisible="state == 'draft'"
                            class="btn-secondary"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,active,achieved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Goal Details">
                            <field name="department_id"/>
                            <field name="goal_type"/>
                            <field name="unit"/>
                            <field name="responsible_id"/>
                        </group>
                        <group string="Targets">
                            <field name="target_value"/>
                            <field name="current_value"/>
                            <field name="progress_percentage" widget="progressbar"/>
                            <field name="baseline_value"/>
                        </group>
                    </group>
                    <group>
                        <group string="Timeline">
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                        <group string="Notes">
                            <field name="notes" nolabel="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_esg_environmental_goal_search" model="ir.ui.view">
        <field name="name">esg.environmental.goal.search</field>
        <field name="model">esg.environmental.goal</field>
        <field name="arch" type="xml">
            <search string="Search Environmental Goals">
                <field name="name"/>
                <field name="department_id"/>
                <field name="goal_type"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Active" name="active" domain="[('state', '=', 'active')]"/>
                <filter string="Achieved" name="achieved" domain="[('state', '=', 'achieved')]"/>
                <filter string="Missed" name="missed" domain="[('state', '=', 'missed')]"/>
                <group expand="0" string="Group By">
                    <filter string="Department" name="group_dept" context="{'group_by': 'department_id'}"/>
                    <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Goal Type" name="group_type" context="{'group_by': 'goal_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_esg_environmental_goal" model="ir.actions.act_window">
        <field name="name">Environmental Goals</field>
        <field name="res_model">esg.environmental.goal</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_esg_environmental_goal_search"/>
        <field name="context">{}</field>
    </record>
</odoo>
