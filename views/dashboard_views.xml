<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Client action for OWL ESG Dashboard -->
    <record id="action_esg_dashboard_client" model="ir.actions.client">
        <field name="name">ESG Dashboard</field>
        <field name="tag">esg_dashboard</field>
    </record>

    <!-- Department Score Graph view action (fallback) -->
    <record id="action_esg_dept_score_graph" model="ir.actions.act_window">
        <field name="name">ESG Department Scores</field>
        <field name="res_model">esg.department.score</field>
        <field name="view_mode">graph,pivot,list</field>
        <field name="context">{}</field>
    </record>
</odoo>
