<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="fleet_vehicle_log_services_view_form_inherit_esg" model="ir.ui.view">
        <field name="name">fleet.vehicle.log.services.form.inherit.esg</field>
        <field name="model">fleet.vehicle.log.services</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_log_services_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='amount']" position="after">
                <field name="liter"/>
                <field name="emission_factor_id"/>
            </xpath>
        </field>
    </record>

    <record id="fleet_vehicle_log_services_view_tree_inherit_esg" model="ir.ui.view">
        <field name="name">fleet.vehicle.log.services.list.inherit.esg</field>
        <field name="model">fleet.vehicle.log.services</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_log_services_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='amount']" position="before">
                <field name="liter" optional="show"/>
                <field name="emission_factor_id" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
