<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record id="view_esg_category_tree" model="ir.ui.view">
        <field name="name">esg.category.tree</field>
        <field name="model">esg.category</field>
        <field name="arch" type="xml">
            <list string="ESG Categories">
                <field name="name"/>
                <field name="category_type"/>
                <field name="parent_id"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_esg_category_form" model="ir.ui.view">
        <field name="name">esg.category.form</field>
        <field name="model">esg.category</field>
        <field name="arch" type="xml">
            <form string="ESG Category">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="category_type"/>
                            <field name="parent_id"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="color"/>
                            <field name="icon"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_esg_category_search" model="ir.ui.view">
        <field name="name">esg.category.search</field>
        <field name="model">esg.category</field>
        <field name="arch" type="xml">
            <search string="Search ESG Categories">
                <field name="name"/>
                <field name="category_type"/>
                <separator/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Type" name="group_type" context="{'group_by': 'category_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_esg_category" model="ir.actions.act_window">
        <field name="name">ESG Categories</field>
        <field name="res_model">esg.category</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_esg_category_search"/>
        <field name="context">{}</field>
    </record>
</odoo>
