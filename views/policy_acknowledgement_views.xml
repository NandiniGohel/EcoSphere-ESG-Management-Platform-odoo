<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record id="view_esg_policy_acknowledgement_tree" model="ir.ui.view">
        <field name="name">esg.policy.acknowledgement.tree</field>
        <field name="model">esg.policy.acknowledgement</field>
        <field name="arch" type="xml">
            <list string="Policy Acknowledgements"
                  decoration-success="state == 'acknowledged'"
                  decoration-warning="state == 'pending'">
                <field name="employee_id"/>
                <field name="policy_id"/>
                <field name="sent_date"/>
                <field name="acknowledged_date"/>
                <field name="state" widget="badge"
                       decoration-warning="state == 'pending'"
                       decoration-success="state == 'acknowledged'"
                       decoration-danger="state == 'overdue'"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_esg_policy_acknowledgement_form" model="ir.ui.view">
        <field name="name">esg.policy.acknowledgement.form</field>
        <field name="model">esg.policy.acknowledgement</field>
        <field name="arch" type="xml">
            <form string="Policy Acknowledgement">
                <header>
                    <button name="action_acknowledge" string="Acknowledge" type="object"
                            invisible="state != 'pending'" class="btn-primary"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="pending,acknowledged"/>
                </header>
                <sheet>
                    <group>
                        <group string="Details">
                            <field name="employee_id"/>
                            <field name="policy_id"/>
                        </group>
                        <group string="Dates">
                            <field name="sent_date"/>
                            <field name="due_date"/>
                            <field name="acknowledged_date"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_esg_policy_acknowledgement_search" model="ir.ui.view">
        <field name="name">esg.policy.acknowledgement.search</field>
        <field name="model">esg.policy.acknowledgement</field>
        <field name="arch" type="xml">
            <search string="Search Policy Acknowledgements">
                <field name="employee_id"/>
                <field name="policy_id"/>
                <separator/>
                <filter string="Pending" name="pending" domain="[('state', '=', 'pending')]"/>
                <filter string="Acknowledged" name="acknowledged" domain="[('state', '=', 'acknowledged')]"/>
                <filter string="Overdue" name="overdue" domain="[('state', '=', 'overdue')]"/>
                <group expand="0" string="Group By">
                    <filter string="Employee" name="group_emp" context="{'group_by': 'employee_id'}"/>
                    <filter string="Policy" name="group_pol" context="{'group_by': 'policy_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_esg_policy_acknowledgement" model="ir.actions.act_window">
        <field name="name">Policy Acknowledgements</field>
        <field name="res_model">esg.policy.acknowledgement</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_esg_policy_acknowledgement_search"/>
        <field name="context">{}</field>
    </record>
</odoo>
