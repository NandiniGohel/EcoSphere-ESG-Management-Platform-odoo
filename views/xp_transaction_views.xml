<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record id="view_esg_xp_transaction_tree" model="ir.ui.view">
        <field name="name">esg.xp.transaction.tree</field>
        <field name="model">esg.xp.transaction</field>
        <field name="arch" type="xml">
            <list string="XP Transactions"
                  decoration-success="xp_amount &gt; 0"
                  decoration-danger="xp_amount &lt; 0">
                <field name="employee_id"/>
                <field name="date"/>
                <field name="xp_amount"/>
                <field name="transaction_type"/>
                <field name="description"/>
                <field name="source_model"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_esg_xp_transaction_form" model="ir.ui.view">
        <field name="name">esg.xp.transaction.form</field>
        <field name="model">esg.xp.transaction</field>
        <field name="arch" type="xml">
            <form string="XP Transaction">
                <sheet>
                    <group>
                        <group string="Transaction">
                            <field name="employee_id"/>
                            <field name="date"/>
                            <field name="xp_amount"/>
                            <field name="transaction_type"/>
                        </group>
                        <group string="Source">
                            <field name="source_model"/>
                            <field name="source_record_id"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Graph View -->
    <record id="view_esg_xp_transaction_graph" model="ir.ui.view">
        <field name="name">esg.xp.transaction.graph</field>
        <field name="model">esg.xp.transaction</field>
        <field name="arch" type="xml">
            <graph string="XP Transactions" type="bar">
                <field name="date" interval="month"/>
                <field name="xp_amount" type="measure"/>
                <field name="employee_id" type="col"/>
            </graph>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_esg_xp_transaction_search" model="ir.ui.view">
        <field name="name">esg.xp.transaction.search</field>
        <field name="model">esg.xp.transaction</field>
        <field name="arch" type="xml">
            <search string="Search XP Transactions">
                <field name="employee_id"/>
                <field name="transaction_type"/>
                <separator/>
                <filter string="This Month" name="this_month"
                        domain="[('date', '&gt;=', (context_today() + relativedelta(day=1)).strftime('%Y-%m-%d'))]"/>
                <filter string="Positive XP" name="positive" domain="[('xp_amount', '&gt;', 0)]"/>
                <filter string="Negative XP" name="negative" domain="[('xp_amount', '&lt;', 0)]"/>
                <group expand="0" string="Group By">
                    <filter string="Employee" name="group_emp" context="{'group_by': 'employee_id'}"/>
                    <filter string="Type" name="group_type" context="{'group_by': 'transaction_type'}"/>
                    <filter string="Month" name="group_month" context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_esg_xp_transaction" model="ir.actions.act_window">
        <field name="name">XP Transactions</field>
        <field name="res_model">esg.xp.transaction</field>
        <field name="view_mode">list,graph,form</field>
        <field name="search_view_id" ref="view_esg_xp_transaction_search"/>
        <field name="context">{}</field>
    </record>
</odoo>
